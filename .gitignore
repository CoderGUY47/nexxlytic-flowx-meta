frontend/build/
backend/dist/

# --- Logs ---
backend/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS / Editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

