# ========================================
# NEXXLYTIC FlowX — Environment Variables
# ========================================

# Server
PORT=5000
NODE_ENV=production

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=nexxlytic_user
DB_PASSWORD=your_strong_password_here
DB_NAME=nexxlytic_flowx

# JWT Secret (change this to a random 64-char string)
JWT_SECRET=your_super_secret_jwt_key_change_this_now_minimum_64_chars
JWT_EXPIRES_IN=7d

# WhatsApp Business API (Meta Cloud API)
WA_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WA_ACCESS_TOKEN=your_whatsapp_permanent_access_token
WA_VERIFY_TOKEN=your_webhook_verify_token_any_string

# Instagram / Facebook (Meta Graph API)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PAGE_ACCESS_TOKEN=your_page_access_token
IG_USER_ID=your_instagram_user_id

# WhatsApp display number for wa.me links (e.g. 919876543210 with country code)
WA_PHONE_DISPLAY=919876543210

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=https://yourdomain.com

# Razorpay (optional)
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
