# ============================================================
# NEXXLYTIC FlowX — Environment Variables (Backend)
# ============================================================
# Copy this file to .env and fill in your real values
# NEVER commit .env to git!
# ============================================================

# --- SERVER ---
PORT=5000
NODE_ENV=production

# --- DATABASE (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=nexxlytic_user
DB_PASSWORD=your_strong_password_here
DB_NAME=nexxlytic_flowx

# --- JWT AUTH ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_64_chars_change_this_now
JWT_EXPIRES_IN=7d

# --- WHATSAPP (Meta Cloud API) ---
WA_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WA_ACCESS_TOKEN=your_whatsapp_permanent_access_token
WA_VERIFY_TOKEN=your_webhook_verify_token_any_string
WA_PHONE_DISPLAY=919876543210

# --- INSTAGRAM / FACEBOOK ---
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PAGE_ID=your_meta_page_id
META_PAGE_ACCESS_TOKEN=your_page_access_token
IG_USER_ID=your_instagram_user_id

# --- AI ---
OPENAI_API_KEY=your_openrouter_or_openai_api_key_here

# --- FRONTEND (CORS) ---
# Set this to your Vercel deployment URL
FRONTEND_URL=https://your-project.vercel.app

# --- PAYMENTS (optional) ---
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
